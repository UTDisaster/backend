# --- Runtime mode ---
APP_ENV=dev

# --- Database ---
# APP_ENV=prod uses DATABASE_URL.
# For production Supabase, use pooled connection string.
DATABASE_URL=postgresql+psycopg://utd:utdpass@db:5432/utd_data
# APP_ENV=dev uses DEV_DATABASE_URL.
# For Dockerized backend in dev, host=db and port=5432.
# For host-run backend in dev, host=127.0.0.1 and port=5433.
DEV_DATABASE_URL=postgresql+psycopg://utd:utdpass@db:5432/utd_data

# --- Gemini ---
GEMINI_API_KEY=your_gemini_key_here

# --- Image content ---
# APP_ENV=prod uses IMAGE_CONTENT_BASE_URL.
IMAGE_CONTENT_BASE_URL=http://127.0.0.1:8000/assets
# APP_ENV=dev uses DEV_IMAGE_CONTENT_BASE_URL.
DEV_IMAGE_CONTENT_BASE_URL=http://127.0.0.1:8000/assets

# --- Local preprocessing ---
PARSED_DATA_DIR=data-example
# Optional: override the VLM dataset directory (defaults to PARSED_DATA_DIR).
VLM_DATASET_DIR=

# --- CORS ---
CORS_ALLOW_ORIGIN_REGEX=^https://.*\.vercel\.app$
# Optional: comma-separated list of explicit origins. Takes precedence over the regex.
CORS_ALLOW_ORIGINS=
